# Docker ignore file
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Virtual environment
venv/
env/
ENV/

# Environment files (will be mounted)
.env

# Uploaded files and reports (will be mounted as volumes)
uploads/*
reports/*
data/*

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Documentation (not needed in container)
*.md
!README.md

# Scripts (not needed in container)
start.sh
start.bat

# Logs
*.log
logs/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Temporary files
*.tmp
temp/
