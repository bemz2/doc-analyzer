# LLM Provider Configuration
# Choose: openai, anthropic, or custom (for local models like Ollama, LM Studio, etc.)
# Note: API keys should be configured via the web UI, not here
LLM_PROVIDER=openai

# API Keys - Leave empty, configure via web UI
# These are only used as fallback defaults if no settings are saved in the database
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Custom/Local Model Configuration (for Ollama, LM Studio, vLLM, etc.)
# For Docker: use host.docker.internal instead of localhost
CUSTOM_API_BASE=http://host.docker.internal:11434/v1
CUSTOM_API_KEY=
CUSTOM_MODEL=llama2

# Model Configuration
# These are default models, can be changed in the web UI
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Document Processing Settings
MAX_FILE_SIZE_MB=100          # Maximum file size in megabytes
CHUNK_SIZE=6000              # Chunk size in tokens
CHUNK_OVERLAP=200            # Overlap between chunks in tokens

# LLM Settings
TEMPERATURE=0.1              # Temperature for LLM generation (0.0 - 1.0)
MAX_RETRIES=3                # Maximum number of retry attempts
RETRY_DELAY=5                # Delay between retries in seconds
BATCH_SIZE=3                 # How many chunks to send in a single LLM request (1 = per-chunk)
REQUEST_DELAY=0.5            # Delay (seconds) between consecutive LLM requests

# Paths
UPLOAD_DIR=uploads           # Directory for uploaded files
REPORT_DIR=reports           # Directory for generated reports

# Logging
LOG_LEVEL=INFO               # Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
